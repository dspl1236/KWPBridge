;
; measuring blocks & basic setting
;
;---------------------------------------------------
;
;
001,0,General
001,1,Compressor,Shut-Off Code,Specification: 0/6/7/8\n\n0 = Compressor ON\n1 = Compressor OFF: Refrigerant Pressure too high (above 32 bar)\n2 = Compressor OFF: Blower faulty or Blower Voltage too low (below 3 V)\n3 = Compressor OFF: Refrigerant Pressure too low (below 2 bar)\n5 = Compressor OFF: Engine Start not detected (Engine Runtime less than 4 Seconds)\n6 = Compressor OFF: Shut-Off via Control Panel (ECON-Mode)\n7 = Compressor OFF: Shut-Off via Control Panel (OFF)\n8 = Compressor OFF: Outside Temperature too low (below 3 ḞC)\n10 = Compressor OFF: Supply Voltage too low\n11 = Compressor OFF: Coolant Temperature too high (above 118 ḞC)\n12 = Compressor OFF: Shut-Off via Engine Control Module (ECM)\n13 = Compressor OFF: Supply Voltage too high (about 17 V)\n14 = Compressor OFF: Evaporator Temperature too low (Risk of Icing)\n15 = Compressor OFF: Control Module Coding incorrect\n16 = Compressor OFF: Activation Signal faulty (Short or Open)\n17 = Compressor OFF: Refrigerant Pressure Sensor implausible Signal
;  0 = Compressor ON
;  1 = Compressor OFF: Refrigerant Pressure too high (above 32 bar)
;  2 = Compressor OFF: Blower faulty or Blower Voltage too low (below 3 V)
;  3 = Compressor OFF: Refrigerant Pressure too low (below 2 bar)
;  5 = Compressor OFF: Engine Start not detected (Engine Runtime less than 4 Seconds)
;  6 = Compressor OFF: Shut-Off via Control Panel (ECON-Mode)
;  7 = Compressor OFF: Shut-Off via Control Panel (OFF)
;  8 = Compressor OFF: Outside Temperature too low (below 3 ḞC)
; 10 = Compressor OFF: Supply Voltage too low
; 11 = Compressor OFF: Coolant Temperature too high (above 118 ḞC)
; 12 = Compressor OFF: Shut-Off via Engine Control Module (ECM)
; 13 = Compressor OFF: Supply Voltage too high (about 17 V)
; 14 = Compressor OFF: Evaporator Temperature too low (Risk of Icing)
; 15 = Compressor OFF: Control Module Coding incorrect
; 16 = Compressor OFF: Activation Signal faulty (Short or Open)
; 17 = Compressor OFF: Refrigerant Pressure Sensor implausible Signal
001,2,Engine Speed
001,3,Vehicle Speed
001,4,Standing Time
;
B001,0,Potentiometer && Flap Alignment
B001,1, , , 
B001,2, , , 
B001,3, , , 
B001,4, , , 
B001,11,The Basic Setting (Duration max. 30 Seconds) must be performed when:
B001,12,- Climatronic Control Module (J255) or Display/Operating Unit Rear (E265) replaced
B001,13,- Flap Motor or Fan Control replaced
;
002,0,Compressor
002,1,Compressor,Current (actual)
002,2,Compressor,Current (specified)
002,3,Compressor,Rotations
002,4,Compressor Load
;
003,1,Refrigerant,Pressure
003,2,Radiator Fan,Activation (actual)
003,3,Radiator Fan,Activation (spec.)
003,4,Engine Speed,(increase)
;
004,0,Temperatures
004,1,Outside Temp.,Unfiltered,Display Range: -50...+63 ḞC
004,2,Outside Temp.,Regulation,Display Range: -50...+77 ḞC
004,3,Fresh Air Intake,Temperature,Display Range: -40...+60 ḞC
004,4,Coolant,Temperature,Display Range: -48...+126 ḞC
;
005,0,Outlet/Footwell Blower Temperature
005,1,Left Outlet Blower,Temperature,Display Range: 0...84 ḞC
005,2,Right Outlet Blower,Temperature,Display Range: 0...84 ḞC
005,3,Left Footwell,Blower Temp.,Display Range: 0...84 ḞC
005,4,Right Footwell,Blower Temp.,Display Range: 0...84 ḞC
;
006,1,Evaporator,Temperature
006,2,Interior,Temperature
006,3,Left Sunlight,Intensity (G107),W/mĠ
006,4,Right Sunlight,Intensity (G134),W/mĠ
;
007,1,Turbine Voltage,(actual),Display Range: 0.0...13.0 V
007,2,Turbine Voltage,(specified),Display Range: 0.0...13.0 V
007,3,Turbine Load,,Display Range: 0.0...100.0 %
007,4,Voltage,(Terminal 30)
