008,1,Voltage,(Terminal 15)
008,3,Dimming,(Terminal 58d),Display Range: 0.0...100.0 %
008,4,Country,,0 = Rest of World (RoW)\n2 = North America (NAR)\n5 = Japan
;
009,0,Rear Window Heater (Z2) && Aux. Heater
