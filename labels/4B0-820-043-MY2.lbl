012,0,General
012,1,Engine Speed
012,2,Vehicle Speed
012,3,Compressor,Torque Status,0 = Compressor Torque Signal current\n1 = Compressor Torque Signal outdated
012,4,Compressor,Torque
;
013,0,Voltage Supply
013,1,Fresh Air Blower,(V2) actual,Tolerance (to Specification): < 0.7 V
013,2,Fresh Air Blower,(V2) specified,Specification: 0.0...12.5 V
013,3,Dimming,Terminal 58d,Range: 0.0...100.0 %
013,4,Dimming,Terminal 58s,Range: 0.0...100.0 %
;
014,1,Radiator Fan,(V7) specified,Range: 0.0...100.0 %
014,2,Radiator Fan,(V7) actual,Range: 0.0...100.0 %
014,3,Radiator Fan,(V7) Ansteuerung,1 = Stage 1\n10 = Stage 2
;
015,1,Fresh/Recirc.,Air Mode Request,See Factory Repair Manual for further Details\n\n00 = Recirculation NOT requested\n10 = Recirculation requested by Air Quality Sensor (G238)\n11 = Recirculation requested but rejected (Automatic Recirculation inactive)\n12 = Recirculation requested but rejected (Compressor OFF)\n13 = Recirculation requested but rejected (Defrost active)\n20 = Manual Recirculation active\n30 = Recirculation active (Front Wiper/Washer active)\n40 = Recirculation active (High Ambient Temperature)\n50 = Recirculation active (A/C deactivated by Driver)\n60 = Partial Recirculation active
; 00 = Recirculation NOT requested
; 10 = Recirculation requested by Air Quality Sensor (G238)
; 11 = Recirculation requested but rejected (Automatic Recirculation inactive)
; 12 = Recirculation requested but rejected (Compressor OFF)
; 13 = Recirculation requested but rejected (Defrost active)
; 20 = Manual Recirculation active
; 30 = Recirculation active (Front Wiper/Washer active)
; 40 = Recirculation active (High Ambient Temperature)
; 50 = Recirculation active (A/C deactivated by Driver)
; 60 = Partial Recirculation active
015,2,Air Quality,Sensor (G238),See Factory Repair Manual for further Details\n\n0 = Missing Signal from Air Quality Sensor (G238)\n1 = Recirculation requested: Low Increase in oxidisable Gases \n2 = Recirculation requested: High Increase in oxidisable Gases\n3 = Recirculation requested: Low Increase in reducible Gases\n4 = Recirculation requested: High Increase in reducible Gases\n5 = Recirculation NOT requested (Fresh Air Mode/No Pollution recognised)\n7 = Recirculation NOT requested (Fresh Air Mode/No Pollution recognised)\n254 = Missing Signal from Air Quality Sensor (G238)\n255 = Missing Signal from Air Quality Sensor (G238)
;   0 = Missing Signal from Air Quality Sensor (G238)
;   1 = Recirculation requested: Low Increase in oxidisable Gases
;   2 = Recirculation requested: High Increase in oxidisable Gases 
;   3 = Recirculation requested: Low Increase in reducible Gases
;   4 = Recirculation requested: High Increase in reducible Gases
;   5 = Recirculation NOT requested (Fresh Air Mode/No Pollution recognised)
;   7 = Recirculation NOT requested (Fresh Air Mode/No Pollution recognised)
; 254 = Missing Signal from Air Quality Sensor (G238)
; 255 = Missing Signal from Air Quality Sensor (G238)
;
016,1,Rear Window,Heating (Z1),Range: ON/OFF
016,2,Front Window,Heating (Z2),1x = Front Window Heating Activation ON\nx1 = Front Window Heating ON
016,3,Auxiliary,Heater,Range: ON/OFF
016,4,Aux. Heater,Shut-Off Criteria,See Factory Repair Manual for further Details\n\n0 = Aux. Heater ON\n1 = Aux. Heater OFF: Ambient Temperature above 5 °C\n2 = Aux. Heater OFF: Blow-Out Temperature below 50 °C\n3 = Aux. Heater OFF: Temperature Flap less than 10 % opened\n4 = Aux. Heater OFF: Blow-Out Temperature below 42 °C\n5 = Aux. Heater OFF: System deactivated via ECON/OFF\n6 = Aux. Heater OFF: Temperature Flap less than 25 % opened
; 0 = Aux. Heater ON
; 1 = Aux. Heater OFF: Ambient Temperature above 5 °C
; 2 = Aux. Heater OFF: Blow-Out Temperature below 50 °C
; 3 = Aux. Heater OFF: Temperature Flap less than 10 % opened
; 4 = Aux. Heater OFF: Blow-Out Temperature below 42 °C
; 5 = Aux. Heater OFF: System deactivated via ECON/OFF
; 6 = Aux. Heater OFF: Temperature Flap less than 25 % opened
;
017,0,Sun Intensity (G107)
017,1,Sun Intensity,Left Side (G107),Range: 0...1000 W/m˛
017,2,Sun Intensity,Right Side (G107),Range: 0...1000 W/m˛
017,3,Front Window,Washer Pump,Range: ON/OFF
017,4,Front Wiper,,Range: ON/OFF
;
018,1,Voltage,(Terminal 75)
018,2,Voltage,(Terminal 15)
018,3,Standing Time
018,4,Ignition Key
