001,2,Wheel Speed,Front Right (G45),Display Range: 0.0...255.0 km/h
001,3,Wheel Speed,Rear Left (G46),Display Range: 0.0...255.0 km/h
001,4,Wheel Speed,Rear Right (G44),Display Range: 0.0...255.0 km/h
;
