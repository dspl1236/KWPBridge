002,2,Brake Light Switch,(F47),Display Range: 0/operated
002,3,Parking Brake,Switch (F9),Display Range: 0/operated
002,4,ASR/ESP-Button,(E256),Display Range: 0/operated
;
B002,0,Brake System Bleeding
B002,1,Status, , 
B002,2, , , 
B002,3, , , 
B002,4, , , 
