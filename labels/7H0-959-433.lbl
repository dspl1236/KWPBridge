015,0,Alarm Sources
; 1 = Driver Door Rotary Switch
; 2 = Passenger Door Rotary Switch
; 4 = Rear Left Door Rotary Switch
; 8 = Rear Right Door Rotary Switch
; 16 = Rear Lid Rotary Switch
; 17 = Immobilizer Recognition
; 18 = Backup Horn
; 32 = Hood Contact Switch
; 64 = Ignition (Terminal 15)
; 128 = Interior Monitoring
; 255 = No Alarm
015,1,1st Alarm Source,,1 = Driver Door Rotary Switch\n2 = Passenger Door Rotary Switch\n4 = Rear Left Door Rotary Switch\n8 = Rear Right Door Rotary Switch\n16 = Rear Lid Rotary Switch\n17 = Immobilizer Recognition\n18 = Backup Horn\n32 = Hood Contact Switch\n64 = Ignition (Terminal 15)\n128 = Interior Monitoring\n255 = No Alarm
015,2,2nd Alarm Source,,1 = Driver Door Rotary Switch\n2 = Passenger Door Rotary Switch\n4 = Rear Left Door Rotary Switch\n8 = Rear Right Door Rotary Switch\n16 = Rear Lid Rotary Switch\n17 = Immobilizer Recognition\n18 = Backup Horn\n32 = Hood Contact Switch\n64 = Ignition (Terminal 15)\n128 = Interior Monitoring\n255 = No Alarm
015,3,3rd Alarm Source,,1 = Driver Door Rotary Switch\n2 = Passenger Door Rotary Switch\n4 = Rear Left Door Rotary Switch\n8 = Rear Right Door Rotary Switch\n16 = Rear Lid Rotary Switch\n17 = Immobilizer Recognition\n18 = Backup Horn\n32 = Hood Contact Switch\n64 = Ignition (Terminal 15)\n128 = Interior Monitoring\n255 = No Alarm
015,4,4th Alarm Source,,1 = Driver Door Rotary Switch\n2 = Passenger Door Rotary Switch\n4 = Rear Left Door Rotary Switch\n8 = Rear Right Door Rotary Switch\n16 = Rear Lid Rotary Switch\n17 = Immobilizer Recognition\n18 = Backup Horn\n32 = Hood Contact Switch\n64 = Ignition (Terminal 15)\n128 = Interior Monitoring\n255 = No Alarm
