; 1xx = Clutch Pedal Switch (F36) open
; x1x = Brake Pedal Switch (F47) open
; xx1 = Brake Light Switch (F) closed
006,3,Accel. Pedal Pos.,Sensor 1 (G79),Range: 0.0...100.0 %
006,4,Cruise Control,Switch Monitoring,0 = CCS Enabled / System Switched OFF\n1 = CCS Enabled / System Switched ON\n255 = CCS Disabled/Not Installed
; 0 = CCS Enabled / System Switched OFF
; 1 = CCS Enabled / System Switched ON
; 255 = CCS Disabled/Not Installed
;
