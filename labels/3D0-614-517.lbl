;---------------------------------------------------
;
; measuring blocks & basic setting
;
;---------------------------------------------------
;
;
001,0,Current Wheel Speed
001,1,Speed Sensor,Front Left (G47),Range: 0.0...255.0 km/h (1.0 km/h while Standing)
001,2,Speed Sensor,Front Right (G45),Range: 0.0...255.0 km/h (1.0 km/h while Standing)
001,3,Speed Sensor,Rear Left (G46),Range: 0.0...255.0 km/h (1.0 km/h while Standing)
001,4,Speed Sensor,Rear Right (G44),Range: 0.0...255.0 km/h (1.0 km/h while Standing)
;
B001,0,Steering Angel Sensor (G85) Alignment
B001,1,Steering Angel,Sensor (G85), 
B001,2,Alignment, , 
B001,3,Alignment,Status,Specification: OK
B001,4, , , 
;
002,0,Switches && Buttons
002,1,Brake Test Switch,(F47),Range: 0/operated
002,2,Brake Light Switch,(F),Range: 0/operated
002,3,Parking Brake,Switch (F9),Range: 0/operated
002,4,ASR/ESP Button,(E256),Range0/operated
;
003,0,Engine Data
003,1,Engine Speed
003,2,Engine Torque
003,3,Engine Torque,(loss)
003,4,Throttle Valve Angle
;
004,1,Standing Time
004,2,EDL-T Flag,,Range: ON/OFF\nSpecification: OFF
;
005,1,Steering Angle,Sensor (G85),Display Range: -720.0...+720.0 °\nTolerance (when straight): ±5.0 °
005,2,Rotation Rate,,Display Range: -69.0...+69.0 °/s
005,3,Brake Pressure,,Display Range: -41.0...+292.0 bar\n40.0 bar = Short to Ground\n290.0 bar = Short to Plus
005,4,Transverse,Acceleration,Display Range: -25.0...+25.0 m/s˛
;
006,1,Supply Voltage,(Terminal 30),Specification: 9.8...17.4 V
006,2,Valve Relay,(J106),Display Range: ON = OK / OFF = not OK
006,3,Return Flow Pump,(V39),Display Range: ON/OFF
006,4,Work Shop Code
;
007,0,Installation Position
; not OK => check brake temperature (test applies only to room temperature)
;        => Check installation of sensor (fully inserted, firmly screwed in)
;        => Check wheel bearing
;        => Check tolerance of axle
007,1,Speed Sensor,Front Left (G47),Range: invalid/OK/not OK
007,2,Speed Sensor,Front Right (G45),Range: invalid/OK/not OK
007,3,Speed Sensor,Rear Left (G46),Range: invalid/OK/not OK
007,4,Speed Sensor,Rear Right (G44),Range: invalid/OK/not OK
;
008,0,Direction of Rotation
008,1,Speed Sensor,Front Left (G47),Range: invalid/forward/reverse (invalid when not moving)
008,2,Speed Sensor,Front Right (G45),Range: invalid/forward/reverse (invalid when not moving)
008,3,Speed Sensor,Rear Left (G46),Range: invalid/forward/reverse (invalid when not moving)
008,4,Speed Sensor,Rear Right (G44),Range: invalid/forward/reverse (invalid when not moving)
;
009,1,Brake Test Switch,(F47),'Activated' shows when brake pedal is pressed
009,2,Brake Light Switch,(F),'Activated' shows when brake pedal is pressed
009,3,Brake Pressure,,Display Range: -41.0...+292.0 bar\n40.0 bar = Short to Ground\n290.0 bar = Short to Plus
;
080,0,Advanced Control Module Identification I
;
125,0,CAN-Databus Communication (Powertrain)
125,1,Steering Angle,Sensor (G85),Specification: Steer. ang. 1\nDisplay Range: Steer. ang. 0/Steer. ang. 1
125,2,Transmission,,Display Range: Transm. 1/Transm. 0
125,3,Engine,,Specification: Engine 1\nRange: Engine 0/Engine 1
125,4,Instrument Cluster,(J285),Specification: Instruments 1\nRange: Instruments 0/Instruments 1
;
