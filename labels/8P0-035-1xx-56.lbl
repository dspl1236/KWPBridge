001,0,General
001,1,Voltage,(Terminal 30),Specification: 9.0...15.0 V
001,2,Amplifier,Output,only if Amplifier installed
001,3,Telephone
001,4,Telephone,Mute Signal,Range: ON/OFF
;
002,0,Speaker/Line-Out (Front Left)
002,1,Location/Type
002,2,Status
;
003,0,Remote Feed Antenna I
