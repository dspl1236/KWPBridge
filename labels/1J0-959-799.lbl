;
013,0,Remote Control
013,1,Permanent Code,known,Range: OK/n.OK
013,2,Code within,effective Range,Range: OK/n.OK
013,3,Algorithm,Status,Range: OK/n.OK
013,4,Remote Control,Key Number,Range: 0...4 (0 = not operated)
;
014,1,Supply Voltage,(Terminal 30)
014,2,Rear Lid Button (E188),Rear Lid Handle (E234),Range: not operated/remote switch/lid lever/implausible
014,3,Interior Monitoring,Switch-Off (E267),Range: on/off/not installed
014,4,Central Locking,Thermal Protection,?xxxx = Drivers Side\nx?xxx = Passengers Side\nxx?xx = Rear Left (RL)\nxxx?x = Rear Right (RR)\nxxxx? = Rear Lid\n\nRange: 0 = inactive / 1 = active
;
015,0,Alarm Source
; Rear Left/Right Value may be reversed based on Control Module Version. Check Measuring Value Blocks (MVB) if in Doubt!
;   1 = Rear Lid/Tailgate Contact Switch
;   2 = Rear Right OR Rear Left Rotary Latch Switch
;   4 = Rear Left OR Rear Right Rotary Latch Switch
;   8 = Passenger Door Rotary Latch Switch
;  16 = Ignition
;  17 = Immobilizer
;  32 = Interior Monitoring
;  64 = Engine Hood Contact Switch
; 128 = Driver's Door Rotary Latch Switch
; 255 = No Alarm
015,1,1st Alarm Source,,1 = Rear Lid/Tailgate Contact Switch\n2 = Rear Right OR Rear Left Rotary Latch Switch\n4 = Rear Left OR Rear Right Rotary Latch Switch\n8 = Passenger Door Rotary Latch Switch\n16 = Ignition\n17 = Immobilizer\n32 = Interior Monitoring\n64 = Engine Hood Contact Switch\n128 = Driver's Door Rotary Latch Switch\n255 = No Alarm\n\nRear Left/Right Value may be reversed based on Control Module Version. Check Measuring Value Blocks (MVB) if in Doubt!
015,2,2nd Alarm Source,,1 = Rear Lid/Tailgate Contact Switch\n2 = Rear Right OR Rear Left Rotary Latch Switch\n4 = Rear Left OR Rear Right Rotary Latch Switch\n8 = Passenger Door Rotary Latch Switch\n16 = Ignition\n17 = Immobilizer\n32 = Interior Monitoring\n64 = Engine Hood Contact Switch\n128 = Driver's Door Rotary Latch Switch\n255 = No Alarm\n\nRear Left/Right Value may be reversed based on Control Module Version. Check Measuring Value Blocks (MVB) if in Doubt!
015,3,3rd Alarm Source,,1 = Rear Lid/Tailgate Contact Switch\n2 = Rear Right OR Rear Left Rotary Latch Switch\n4 = Rear Left OR Rear Right Rotary Latch Switch\n8 = Passenger Door Rotary Latch Switch\n16 = Ignition\n17 = Immobilizer\n32 = Interior Monitoring\n64 = Engine Hood Contact Switch\n128 = Driver's Door Rotary Latch Switch\n255 = No Alarm\n\nRear Left/Right Value may be reversed based on Control Module Version. Check Measuring Value Blocks (MVB) if in Doubt!
015,4,4th Alarm Source,,1 = Rear Lid/Tailgate Contact Switch\n2 = Rear Right OR Rear Left Rotary Latch Switch\n4 = Rear Left OR Rear Right Rotary Latch Switch\n8 = Passenger Door Rotary Latch Switch\n16 = Ignition\n17 = Immobilizer\n32 = Interior Monitoring\n64 = Engine Hood Contact Switch\n128 = Driver's Door Rotary Latch Switch\n255 = No Alarm\n\nRear Left/Right Value may be reversed based on Control Module Version. Check Measuring Value Blocks (MVB) if in Doubt!
;
016,1,Immobilizer,Key Recognition,Range: yes/no/not installed
016,2,Automatic,Lock/Unlock Switch,Range: operated/not oper./implausible
016,3,Rear Lid,first Detent,Range: open/closed/not installed
;
;
;---------------------------------------------------
;
; coding
;
;---------------------------------------------------
;
;
C00,Comfort System (J393) Coding
C01,Central Locking (2-Power Windows):
C02,00256 = Selective unlocking
C03,00257 = Unlocking of all doors
C04, 
C05,Central Locking (2-Power Windows and Memory Seats):
C06,00258 = Selective unlocking
C07,00259 = Unlocking of all doors
C08, 
C09,Central Locking (4-Power Windows):
C10,04096 = Selective unlocking
C11,04097 = Unlocking of all doors
C12, 
C13,Central Locking (4-Power Windows and Memory Seats):
C14,04098 = Selective unlocking
C15,04099 = Unlocking of all doors
;
;
;---------------------------------------------------
;
; adaptation
;
;---------------------------------------------------
;
;
A01,0,Remote control adaptation
A01,5,Remote control adaptation
A01,6,Enter the number of keys that should be adapted. Save.
A01,7, 
A01,8,Now press button 1 or 2 on every remote that
A01,9,should be adapted for at least 1 second.
A01,10, 
A01,11,Note #1: All keys must be adapted in one procedure.
A01,12,Note #2: Adaptation of all keys must not exceed 15 seconds.
;
A003,0,Auto-Lock
A003,5,Auto-Lock
A003,6,The doors will lock automatically when the
A003,7,vehicle reaches a speed of 15 km/h or 10 mph.
A003,8, 
A003,9,Range: 0 = OFF / 1 = ON
;
A004,0,Auto-Unlock
A004,5,Auto-Unlock
A004,6,The doors will unlock automatically when the key
A004,7,is removed from the ignition switch.
A004,8, 
A004,9,Range: 0 = OFF / 1 = ON
;
A005,0,Interior Monitoring
A005,5,Interior Monitoring
A005,6,Activation of interior monitoring system.
A004,7, 
A004,8,Range: 0 = OFF / 1 = ON
;
A006,0,Unlock Horn
A006,5,Unlock Horn
A006,6,Horn beep when unlocking via remote control.
A006,7, 
A006,8,Range: 0 = OFF / 1 = ON
;
A007,0,Lock Horn
A007,5,Lock Horn
A007,6,Horn beep when locking via remote control.
A007,7, 
A007,8,Range: 0 = OFF / 1 = ON
;
A008,0,Unlock Blink
A008,5,Unlock Blink
A008,6,Blink when unlocking via remote control.
A008,7, 
A008,8,Range: 0 = OFF / 1 = ON
;
A009,0,Lock Blink
A009,5,Lock Blink
A009,6,Blink when locking via remote control.
A009,7, 
A009,8,Range: 0 = OFF / 1 = ON
;
A010,0,Country Setting
A010,5,Country Setting
A010,6,Country setting for Alarm Horn.
A010,7, 
A010,8,1 = Rest of World (RoW)
A010,9,2 = Germany (DE)
A010,10,3 = Great Britain (GB)
;
