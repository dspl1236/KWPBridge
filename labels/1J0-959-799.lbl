;
001,0,General (Driver Side)
001,1,Child Safety Lock,Button (E319),Range: Yes/No/Not Installed
001,2,Interior Locking,Button (E150),Range:  Lock/Unlock/Not Oper./Not Installed
001,3,Window Regulator,Hall Signal,Range: Rotating/Stop
;
002,0,Window Regulator Buttons (Driver's Door)
002,1,WR-Button (E40),Driver Door,Range: auto. open/auto. close/man. open/man. close/close not operated/implausible
002,2,WR-Button (E81),Passenger Door,Range: autom. open/autom. close/man. open/man. close/not operated/implausible
002,3,WR-Button (E53),Rear Left Door,Range: autom. open/autom. close/man. open/man. close/not operated/implausible
002,4,WR-Button (E55),Rear Right Door,Range: autom. open/autom. close/man. open/man. close/not operated/implausible
;
003,0,Central Locking (Driver Door)
003,1,Central Locking,Key Switch Drv.,Range: open/closed/not operated/implausible
003,2,Rotary Latch &,Thermal-Protection,0x = Rotary Latch/Door closed\n1x = Rotary Latch/Door open\nx0 = Thermal Protection active\nx1 = Thermal Protection inactive
003,3,Central Locking,Feedback Driver,Range: Locked/Unlocked
003,4,Safe Feedback,Driver Door,Range: safe/not safe
;
004,0,Mirror Adjustment && Folding
004,1,Mirror Adjustment,Switch Driver (E43),Range: Pos X+/Pos X-/Pos Y+/Pos Y-/not operated
004,2,Mirror Selection,Switch Driver (E48,Range: left/right/fold/not operated
004,3,Mirror Folding,Switch (E263),Range: released/engaged/not installed
;
005,0,General (Passenger Side)
005,1,WR-Button (E107),Passenger Door,Range: autom. open/autom. close/man. open/man. close/not operated/implausible
005,2,Interior Locking,Switch Pass. (E198),Range: Lock/Unlock/Not Oper./Not Installed\n\Note: North American Region (NAR) only
005,3,Mirror Folding,Switch (E263),Range: released/engaged/not installed
;
006,0,Central Locking (Passenger Door)
006,1,Central Locking,Key Switch Pass.,Range: open/closed/not operated/implausible
006,2,Rotary Latch &,Thermal-Protection,0x = Rotary Latch/Door closed\n1x = Rotary Latch/Door open\nx0 = Thermal Protection active\nx1 = Thermal Protection inactive
006,3,Central Locking,Feedback Pass.,Range: Locked/Unlocked
006,4,Safe Feedback,Passenger Door,Range: safe/not safe
;
007,0,Central Locking (Rear Right Door)
007,1,WR-Button (E54),Rear Right Door,Range: autom. open/autom. close/man. open/man. close/not operated/implausible
007,2,Rotary Latch &,Thermal-Protection,0x = Rotary Latch/Door closed\n1x = Rotary Latch/Door open\nx0 = Thermal Protection active\nx1 = Thermal Protection inactive
007,3,Central Locking,Feedback Rear Right,Range: Locked/Unlocked
007,4,Safe Feedback,Rear Right Door,Range: safe/not safe
;
008,0,Central Locking (Rear Left Door)
008,1,WR-Button (E52),Rear Left Door,Range: autom. open/autom. close/man. open/man. close/not operated/implausible
008,2,Rotary Latch &,Thermal-Protection,0x = Rotary Latch/Door closed\n1x = Rotary Latch/Door open\nx0 = Thermal Protection active\nx1 = Thermal Protection inactive
008,3,Central Locking,Feedback Rear Left,Range: Locked/Unlocked
008,4,Safe Feedback,Rear Left Door,Range: safe/not safe
;
009,1,Illuination,(Terminal 58d),Range: 0...100 %
009,2,Vehicle Speed,,Steps: 2 km/h
009,3,Remote Control,Button,Range: Open/Closed/Rear Lid Release/Panic
009,4,Interior Monitoring,Sensor (G273),Range: Yes/No/Not Installed
;
010,1,Terminal S,Status,Range: operated/not operated
010,2,Mirror heating,(E231),Range: on/off/not installed
010,3,Rear Lid/Tailgate,Key Switch (E165),Range: open/closed/not operated/implausible
010,4,Terminal 15,Status,Range: Terminal 15 ON/Terminal 15 OFF
;
011,0,Engine Hood && Rear Lid
011,1,Hood Contact,Switch (F120),Range: operated/not operated/not installed
011,2,Rear Lid/Tailgate,Contact Sw. (F124),Range: open/closed
011,3,Sliding/Tilting,Sunroof released,Range: Yes/No
;
012,0,CAN-Databus Communication
012,1,CAN-Databus,Status,Specification: 2-wire
012,2,Door Control,Modules (Front),Range: Driver/Passenger
012,3,Door Control,Modules (Rear),Range: RL/RL and RR/RR
