;
001,0,Window Regulator
001,1,WR-Button (E40),Driver Door,Range: Auto Open/Auto Close/Manual Open/Manual Close/Not Oper.
001,2,WR-Button (E40),Driver Door,Range: Auto Open/Auto Close/Manual Open/Manual Close/Not Oper.
001,3,Window Regulator,(V147),Range: Up/Down/Ends Learned/At Top/At Bottom/Pinch Protect/Over-Temp S/O\nSpecification: Ends Learned
001,4,Thermal Protection,,Range: Not Active/Active
;
002,0,Window Regulator && General
002,1,Window Regulator,Comfort Control,Range: Open/Closed/Not Oper.
002,2,Window Regulator,Enabling,Range: Yes/No
002,3,Dimming,(Terminal 58d),Range: 0.0...100.0 %
002,4,Vehicle Speed,,Range: 0.0...300.0 km/h
;
003,0,General
003,1,Voltage,(Terminal 30),Range: 0.0...20.0 V\nSpecification: 9.0...14.0 V
003,2,Databus,Condition,Range: 1-Wire/2-Wire\nSpecification: 2-Wire
003,3,Ignition,(Terminal 15),Range: Terminal 15 ON/Terminal 15 OFF
003,4,S-Contact,(Terminal S),Range: Activated
;
004,0,General
004,1,Window Regulator,Position (V147),Range: 0.0...100.0 %
004,2,Internal,Illumination,Display Range: Enabled/Disabled
004,3,Interior Door,Handle Illumination,Display Range: 0.0...100.0 %/Not Installed
004,4,Ambient,Illumination,Display Range: 0.0...100.0 %/Not Installed
;
005,0,Central Locking
005,1,Locking Unit (F220),Driver Door,Range: Locked/Unlocked/Safe
005,2,Contact Switch (F2),Driver Door,Range: Door Open/Door Closed
005,3,Interior Locking,Button (E308),Range: Lock/Unlock/Not Oper./Not Installed
005,4,Key Switch,Driver Door,Range: Open/Closed/Not Oper./Not Installed
;
006,0,Mirror I (Heating && Folding)
006,1,Mirror Selector,Switch (E48),Range: Left/Right/ON (Mirror Heater Switch)/OFF (Mirror Heater Switch)/Not Oper.
006,2,Mirror Heater,(Z4),Display Range: Active/Not Active
;
007,0,Mirror II
007,1,Mirror Adjustment,Switch (E43),Range: Pos X+/Pos X-/Pos Y+/Pos Y-/Not Oper./Not Installed
;
008,1,Mirror Blinker,Driver (L131),Range: Active/Not Active/Not Installed
;
009,0,Central Locking
