004,0,Input/Output Information
004,1,Input,Information 1,00?1xxxx: 0 = Door open / 1 = Door closed\n00x1?xxx: 0 = Starting Sequence inactive (Terminal 50 OFF) / 1 = Starting Sequence active (Terminal 50 ON)\n00x1x?xx: 0 = Selector Lever in "D" / 1 Selector Lever in Tiptronic-Gate\n00x1xx?x: 0 = Hydraulic Pump Relay (J510) active / 1 = Hydraulic Pump Relay (J510) inactive\n00x1xxx?: 0 = ECO-Mode / 1 = Normal Mode
; 00?1xxxx: 0 = Door open / 1 = Door closed
; 00x1?xxx: 0 = Starting Sequence inactive (Terminal 50 OFF) / 1 = Starting Sequence active (Terminal 50 ON)
; 00x1x?xx: 0 = Selector Lever in "D" / 1 Selector Lever in Tiptronic-Gate
; 00x1xx?x: 0 = Hydraulic Pump Relay (J510) active / 1 = Hydraulic Pump Relay (J510) inactive
; 00x1xxx?: 0 = ECO-Mode / 1 = Normal Mode
004,2,Input,Information 2,00010?xx: 0 = Reverse Gear NOT engaged / 1 = Reverse Gear engaged\n00010x?x: 1 = Terminal 30 active\n00010xx?: 0 = Brake Pedal NOT operated / 1 = Brake Pedal operated
; 00010?xx: 0 = Reverse Gear NOT engaged / 1 = Reverse Gear engaged
; 00010x?x: 1 = Terminal 30 active
; 00010xx?: 0 = Brake Pedal NOT operated / 1 = Brake Pedal operated
004,3,Output,Informationen 1,000?xxx0: 0 = ECO-Mode / 1 = Normal Mode\n000x?xx0: 0 = Buzzer/Gear active / 1 = Normal Mode\n000xx?x0: Hydraulic Pump Relay (J510) [0 = active / 1 = inactive]\n000xxx?0: Start Inhibitor/Backup Light Relay (J226) [0 = operated | 1 = not operated]
; 000?xxx0: 0 = ECO-Mode / 1 = Normal Mode
; 000x?xx0: 0 = Buzzer/Gear active / 1 = Normal Mode
; 000xx?x0: Hydraulic Pump Relay (J510) [0 = active / 1 = inactive]
; 000xxx?0: Start Inhibitor/Backup Light Relay (J226) [0 = operated | 1 = not operated]
004,4,Output,Informationen 2,?000xx1x = Valve 3 for Gear Selector (N286) [0 = active/engaged | 1 = inactive/disengaged]\nx000?x1x = Valve 3 for Gear Selector (N286) [0 = active/engaged | 1 = inactive/disengaged]\nx000x?1x = Valve 4 for Gear Selector (N287) [0 = active/engaged | 1 = inactive/disengaged]\nx000xx1? = Valve 4 for Gear Selector (N287) [0 = active/engaged | 1 = inactive/disengaged]
; ?000xx1x = Valve 3 for Gear Selector (N286) [0 = active/engaged | 1 = inactive/disengaged]
; x000?x1x = Valve 3 for Gear Selector (N286) [0 = active/engaged | 1 = inactive/disengaged]
; x000x?1x = Valve 4 for Gear Selector (N287) [0 = active/engaged | 1 = inactive/disengaged]
; x000xx1? = Valve 4 for Gear Selector (N287) [0 = active/engaged | 1 = inactive/disengaged]
;
