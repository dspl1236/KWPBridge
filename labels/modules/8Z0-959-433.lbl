;
;
A021,0,Remote Control matching
;
A060,0,Heater/Air Conditioning
A060,5,Heater/Air Conditioning
A060,6,Altering the Mirror Heating and Rear Window Heating
A060,7,Operation via Heater/Air Conditioning Panel.
A060,8, 
A060,9,0 = Air Conditioning NOT installed
A060,10,1 = Air Conditioning installed
;
A061,0,Variant Reduction
A061,5,Variant Reduction
A061,6,+1 = Rear Mechanical Window Regulators (PR-4R5) installed 
A061,7,+2 = Remote Control installed
