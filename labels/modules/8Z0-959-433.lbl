;
;
001,0,Driver's Side
001,1,Driver's Side,Key Switch,Display Range: Open/Closed/Not Oper.
001,2,Central Locking,Button,Display Range: Locking/Unlocking/Not Oper.
001,3,Driver's Side,Lock Status,Display Range: Locked/Unlocked
001,4,Driver's Side,Safe Status,Display Range: Safe/Not Safe
;
002,0,Driver Side/Passenger Side
002,1,Driver's Side,Key Switch,Display Range: Open/Closed/Not Oper.
002,2,Passenger Side,Key Switch,Display Range: Open/Closed/Not Oper.
002,3,Passenger Side,Lock Status,Display Range: Locked/Unlocked
002,4,Passenger Side,Safe Status,Display Range: Safe/Not Safe
;
003,0,Rear Right/Left (Return Messages)
003,1,Rear Right,Lock Status,Display Range: Locked/Unlocked
003,2,Rear Right,Safe Status,Display Range: Safe/Not Safe
003,3,Rear Left,Lock Status,Display Range: Locked/Unlocked
003,4,Rear Left,Safe Status,Display Range: Safe/Not Safe
;
004,0,Door Contacts (Rotary Traps)
004,1,Door Contact,Driver's Side,Display Range: Door Open/Door Closed
004,2,Door Contact,Passenger Side,Display Range: Door Open/Door Closed
004,3,Door Contact,Rear Right,Display Range: Door Open/Door Closed
004,4,Door Contact,Rear Left,Display Range: Door Open/Door Closed
;
005,1,Fuel Tank,Lid Switch,Display Range: Operated/Not Oper.
005,2,Trunk Lid,Contact Switch,Display Range: Lid Open/Lid Closed
005,3,Soft-Touch,Trunk Lid Release,Display Range: Operated/Not Oper.
005,4,Engine Hood,Contact Switch,Display Range: Lid Open/Lid Closed
;
006,1,Interior Light,,Display Range: ON/OFF
006,2,Window Regulator,Relief Relay,Display Range: Relay ON/Relay OFF
006,3,Comfort Oper.,(open/code),Display Range: Open/Closed/Not Oper.
006,4,Luggage,Compartment Light,Display Range: ON/OFF
;
007,1,Key Number,(Memory Position),0 = Not Operated\n1-4 = Key Number
007,2,Remote Control,Command,0 = Not Operated\n1 = Open\n2 = Close\n3 = Open Rear Lid\n4 = Panic Button
007,3,Adapted Key,Memory Positions,Display Range: 0 = Not Occupied / 1 = Occupied\n\n?xxx = Key 1\nx?xx = Key 2\nxx?x = Key 3\nxxx? = Key 4
;
008,1,Vehicle Speed
008,2,Immobilizer,(Key recognized),Display Range: Yes/No
008,4,Rear Windshield,broken,Display Range: Recognized/No/Not Installed
;
009,0,Control Module,Coding
;
010,1,Driver's Door,(Door Contact),Display Range: Door Open/Door Closed
010,2,Interior Monitoring,Deactivation Button,Display range: operated/Not Oper./Not Installed
010,3,Parking Brake,,Display Range: Operated/Not Oper.
010,4,Back-Up Light,,Display Range: ON/OFF
;
011,0,Fahrertür (Window Regulator)
011,1,eFH-Schalter,Beifahrertür,Wertebereich: autom. auf/autom. zu/man. auf/man. zu/unbetätigt/n. verbaut
011,2,eFH-Thermoschutz,Beifahrertür,Wertebereich: Ja/Nein/n. verbaut
011,3,Window Reg. Lock,Rear Doors,Range: ON/OFF
;
012,0,Fahrertür (eFH-Schalter)
012,1,eFH-Schalter,vorne rechts,Wertebereich: autom. auf/autom. zu/man. auf/man. zu/unbetätigt/n. verbaut
012,2,eFH-Schalter,hinten links,Wertebereich: autom. auf/autom. zu/man. auf/man. zu/unbetätigt/n. verbaut
012,3,eFH-Schalter,hinten rechts,Wertebereich: autom. auf/autom. zu/man. auf/man. zu/unbetätigt/n. verbaut
;
013,0,Mirror System
013,1,Mirror Adjustment,Switch,Display Range: Pos. X+/Pos. X-/Pos. Y+/Pos. Y-/Not Oper.
013,2,Mirror Selection,Switch,Display Range; Left/Right/Fold-Out/Not Oper.
013,3,Mirror Disengage,Switch,Display Range: Disengaged/Engaged/Not Installed
013,4,Mirror Heating,,Display Range: ON/OFF
;
014,0,Passenger Door (Window Regulators)
014,1,Window Regulator,Button Pass. Side,Display Range: auto. open/auto. close/man. open/man. close/Not Oper.
014,2,Window Reg. Therm.,Prot. Pass. Side,Display Range: Yes/No/Not Oper.
