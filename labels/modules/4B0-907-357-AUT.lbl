;
C00,Head Light Aim Control (J431) Coding
C01,00001 = Audi A3 (8L) Front-Wheel-Drive (through MY 2000)
C02,00002 = Audi A3/S3 (8L) All-Wheel-Drive (through MY 2000)
C03,00003 = Audi A4 (8D) Front-Wheel-Drive
C04,00004 = Audi A4/S4 (8D) All-Wheel-Drive
C05,00005 = Audi A6 (4B) Front-Wheel-Drive
C06,00006 = Audi A6 (4B) All-Wheel-Drive
C07,00007 = Audi A8 (4D) Front-Wheel-Drive
C08,00008 = Audi A8/S8 (4D) All-Wheel-Drive
C09,00009 = Audi TT (8N) Front-Wheel-Drive
C10,00010 = Audi TT (8N) All-Wheel-Drive
C11,00013 = Audi A3 (8L) Front-Wheel-Drive (from MY 2001)
C12,00014 = Audi A3/S3 (8L) All-Wheel-Drive (from MY 2001)
C13,00015 = VW Passat (3B) Front-Wheel-Drive
C14,00016 = VW Passat (3B) All-Wheel-Drive
