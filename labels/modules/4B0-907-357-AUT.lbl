001,0,General
001,1,Voltage Supply,(Terminal 15),Range: 0.0...15.0 V
001,2,Voltage,(Terminal 56b),Range: 0.0...15.0 V
001,3,Vehicle Speed,,Specification: 0.0...300.0 km/h
;
B001,0,Adjustment Position (Step 1)
B001,1,Status, , 
B001,2, , , 
B001,3, , , 
B001,4, , , 
;
002,0,General
002,1,Front Level,Sensor (G78),Range: 0.0...5.0 V\nSpecification: 1.56...3.45 V\n0.00 V = Level Sensor faulty\n5.00 V = Wiring faulty
002,2,Rear Level,Sensor (G76),Range: 0.0...5.0 V\nSpecification: 1.56...3.45 V\n0.00 V = Level Sensor faulty\n5.00 V = Wiring faulty
002,3,Adjustment,Status,Range: ADP Run/ADP OKSpecification: ADP OK
;
B002,0,Adjustment Position learning (Step 2)
B002,1,Status, , 
B002,2, , , 
B002,3, , , 
B002,4, , , 
