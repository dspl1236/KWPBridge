001,0,General
001,1,Voltage,(Terminal 15)
001,2,Voltage,(Terminal 56b)
001,3,Vehicle,Speed
001,4,Vehicle,Status,  0 = Vehicle standing (up 5 km/h)\n 85 = Vehicle moving at constant Speed\n255 = Vehicle NOT moving at constant Speed
;   0 = Vehicle standing (up to 5 km/h)
;  85 = Vehicle moving at constant Speed
; 255 = Vehicle NOT moving at constant Speed
;
B001,0,Adjustment Position
B001,1,Status, , 
B001,2, , , 
B001,3, , , 
B001,4, , , 
;
002,0,Sensors && Position Motors
002,1,Front Sensor (G78),(actual),Range: 0.0...5.0 V\nSpecification (standing): 2.3...2.8 V
002,2,Rear Sensor (G76),(actual),Range: 0.0...5.0 V\nSpecification (Front-Wheel-Drive): 1.9...2.3 V\nSpecification (All-Wheel-Drive): 3.5...3.9 V
002,3,Adjustment Signal,Master > Slave
002,4,Adjustment,Position Motor
;
B002,0,Adjustment Learning
B002,1,Status, , 
B002,2, , , 
B002,3, , , 
B002,4, , , 
